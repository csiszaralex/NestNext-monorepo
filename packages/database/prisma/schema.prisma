datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/client"
  moduleFormat = "cjs"
  engineType   = "client"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../../shared-types/src/generated/zod"
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
}
